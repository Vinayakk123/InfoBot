# Copy this file to .env and fill in real values. Never commit .env itself.

# Groq API key — required. Used by ChatGroq (src/search.py) to generate answers.
# Get one at https://console.groq.com/keys (free tier available).
GROQ_API_KEY=your_groq_api_key_here

# Log verbosity for the whole app (src/logger.py). Optional — defaults to INFO.
# Set to DEBUG for per-file ingestion detail, FAISS/embedding internals, etc.
LOG_LEVEL=INFO
